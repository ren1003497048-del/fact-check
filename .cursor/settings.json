{
  // ==========================================
  // Cursor 终端乱码修复配置
  // ==========================================

  // 终端字体设置 - 使用支持中文的等宽字体
  "terminal.integrated.fontFamily": "Cascadia Code, 'Cascadia Mono', 'JetBrains Mono', Consolas, 'SimHei-Console', 'NSimSun', 'monospace',terminal font",

  // 终端字体大小
  "terminal.integrated.fontSize": 13,

  // 行高（提升可读性）
  "terminal.integrated.lineHeight": 1.2,

  // Windows 终端编码设置
  "terminal.integrated.windowsEnableConpty": true,

  // 继承环境变量（确保 UTF-8）
  "terminal.integrated.inheritEnv": true,

  // 终端默认 Shell（Windows）
  "terminal.integrated.defaultProfile.windows": "PowerShell",

  // 字体平滑
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.fontWeightBold": "bold",

  // 字符编码
  "files.encoding": "utf8",
  "files.autoGuessEncoding": true,

  // PowerShell 集成配置
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoLogo", "-ExecutionPolicy", "Bypass", "-NoExit", "-Command", "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8"]
    }
  }
}
